{
  "name": "lexassist-root",
  "private": true,
  "workspaces": ["client", "server"],
  "scripts": {
    "dev": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "dev:all": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace client\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
